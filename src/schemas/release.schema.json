{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Release Manifest",
  "description": "Project manifest for the showcase site. Generated by CI on each release.",
  "type": "object",
  "required": ["slug", "displayName", "tagline", "description", "version", "released", "hero", "accent", "platforms"],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "URL-safe identifier, must match the directory name under /srv/projects/"
    },
    "displayName": {
      "type": "string"
    },
    "tagline": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "description": "Supports markdown"
    },
    "version": {
      "type": "string"
    },
    "released": {
      "type": "string",
      "format": "date-time"
    },
    "hero": {
      "type": "object",
      "required": ["image", "alt"],
      "properties": {
        "image": { "type": "string" },
        "alt": { "type": "string" }
      }
    },
    "accent": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["os", "arch", "file", "label"],
        "properties": {
          "os": { "type": "string", "enum": ["linux", "windows", "macos"] },
          "arch": { "type": "string" },
          "file": { "type": "string" },
          "label": { "type": "string" },
          "size": { "type": "string" }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "install": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
