---
interface Props {
  install: Record<string, string>;
}

const { install } = Astro.props;
const entries = Object.entries(install);
---

{entries.length > 0 && (
  <section class="install">
    <h3>Install</h3>
    <div class="install-list">
      {entries.map(([method, command]) => (
        <div class="install-block">
          <span class="install-label">{method}</span>
          <pre><code>{command}</code></pre>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .install {
    margin-top: 3rem;
    animation: fade-up 0.5s ease-out backwards;
    animation-delay: 0.35s;
  }

  .install h3 {
    margin-bottom: 1rem;
  }

  .install-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .install-block pre {
    user-select: all;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .install-block pre:hover {
    border-color: rgba(168, 85, 247, 0.3);
  }

  .install-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--purple);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.4rem;
  }
</style>
