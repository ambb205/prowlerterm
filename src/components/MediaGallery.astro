---
import type { Media } from '../schemas/release';

interface Props {
  media: Media[];
  slug: string;
}

const { media, slug } = Astro.props;
---

{media.length > 0 && (
  <div class="media-grid">
    {media.map((item, i) => (
      <figure class="media-item" style={`--i: ${i}`}>
        {item.type === 'video' ? (
          <video
            src={`/dl/${slug}/${item.file}`}
            controls
            preload="metadata"
            playsinline
          />
        ) : (
          <img
            src={`/dl/${slug}/${item.file}`}
            alt={item.caption || ''}
            loading="lazy"
          />
        )}
        {item.caption && (
          <figcaption>{item.caption}</figcaption>
        )}
      </figure>
    ))}
  </div>
)}

<style>
  .media-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .media-item {
    animation: fade-up 0.4s ease-out backwards;
    animation-delay: calc(var(--i) * 0.08s);
  }

  .media-item video,
  .media-item img {
    width: 100%;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-surface);
    display: block;
  }

  .media-item video {
    outline: none;
  }

  .media-item video:hover {
    border-color: #3f3f46;
  }

  figcaption {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
    text-align: center;
    letter-spacing: 0.02em;
  }
</style>
