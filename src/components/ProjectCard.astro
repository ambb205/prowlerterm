---
import TagList from './TagList.astro';
import type { Release } from '../schemas/release';

interface Props {
  project: Release;
  index: number;
}

const { project, index } = Astro.props;
---

<a
  href={`/projects/${project.slug}`}
  class="card"
  style={`--accent: ${project.accent}; --i: ${index}`}
>
  <div class="card-hero">
    <img
      src={`/dl/${project.slug}/${project.hero.image}`}
      alt={project.hero.alt}
      loading="lazy"
    />
  </div>
  <div class="card-body">
    <h2 class="card-title">{project.displayName}</h2>
    <p class="card-tagline">{project.tagline}</p>
    <div class="card-meta">
      <span class="card-version">v{project.version}</span>
      <TagList tags={project.tags} />
    </div>
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    animation: fade-up 0.5s ease-out backwards;
    animation-delay: calc(var(--i) * 0.12s);
  }

  .card:hover {
    border-color: #3f3f46;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    transform: translateY(-4px);
    color: var(--text-primary);
  }

  .card-hero {
    overflow: hidden;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
  }

  .card-hero img {
    width: 100%;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .card:hover .card-hero img {
    transform: scale(1.03);
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-title {
    font-size: 1.3rem;
    letter-spacing: -0.02em;
  }

  .card-tagline {
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.375rem;
  }

  .card-version {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--purple);
  }
</style>
