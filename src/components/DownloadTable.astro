---
import PlatformIcon from './PlatformIcon.astro';
import type { Platform } from '../schemas/release';

interface Props {
  platforms: Platform[];
  slug: string;
  version: string;
}

const { platforms, slug, version } = Astro.props;
---

<div class="download-list">
  {platforms.map((platform, i) => (
    <div class="download-row" style={`--i: ${i}`}>
      <div class="download-platform">
        <PlatformIcon os={platform.os} />
        <span>{platform.label}</span>
      </div>
      <span class="download-version">v{version}</span>
      {platform.size && <span class="download-size">{platform.size}</span>}
      <a href={`/dl/${slug}/${platform.file}`} class="download-btn" download>
        Download
      </a>
    </div>
  ))}
</div>

<style>
  .download-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .download-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: border-color 0.2s, background 0.2s;
    animation: fade-up 0.4s ease-out backwards;
    animation-delay: calc(var(--i) * 0.08s);
  }

  .download-row:hover {
    border-color: #3f3f46;
    background: var(--bg-elevated);
  }

  .download-platform {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    font-weight: 500;
    font-size: 0.95rem;
  }

  .download-version,
  .download-size {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .download-btn {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.45rem 1.1rem;
    border-radius: 6px;
    background: var(--accent);
    color: #000;
    transition: filter 0.2s, box-shadow 0.2s;
    letter-spacing: 0.01em;
  }

  .download-btn:hover {
    filter: brightness(1.15);
    box-shadow: 0 0 16px rgba(168, 85, 247, 0.2);
    color: #000;
  }

  @media (max-width: 640px) {
    .download-row {
      flex-wrap: wrap;
    }

    .download-version,
    .download-size {
      display: none;
    }

    .download-btn {
      width: 100%;
      text-align: center;
      margin-top: 0.375rem;
    }
  }
</style>
